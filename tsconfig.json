{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "lib": ["ES2022", "dom"],
        "outDir": "out",
        "rootDir": "./src",
        "sourceMap": true,
        "strict": true,
        "isolatedModules": true,
        "moduleResolution": "node16",
        "types": ["jest", "node"],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "skipLibCheck": true
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ],
    "include": [
        "src/**/*.ts"
    ]
}